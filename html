<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Evelyn Rocha · Links</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;1,9..144,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --shell:#EFE3DD;       /* fundo nude quente */
    --blush:#FBF6F3;       /* superfície dos cards */
    --ink:#4A3B38;         /* texto rosewood */
    --muted:#8C7670;       /* texto secundário */
    --rose:#C68F88;        /* acento rosê */
    --rose-deep:#B87C75;   /* rosê para hover/CTA */
    --line:#E2CFC4;        /* hairline champagne */
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html,body{height:100%}
  body{
    font-family:'Jost',sans-serif;
    background:#F3CBD7 url(data:image/jpeg;base64,) center top / cover;
    color:var(--ink);
    min-height:100dvh;
    display:flex;
    justify-content:center;
    padding:48px 22px 40px;
    -webkit-font-smoothing:antialiased;
  }
  .page{width:100%;max-width:430px;position:relative}

  /* ---- borboletas ---- */
  .frame .bf{position:absolute;z-index:3;pointer-events:none}
  .frame .bf img{display:block;width:100%;transform-origin:50% 50%;
    filter:drop-shadow(0 3px 5px rgba(74,59,56,.22))}
  .frame .bf-top{left:81.5%;top:26.6%;width:47%;transform:translate(-50%,-50%)}
  .frame .bf-bot{left:9.1%;top:82%;width:35%;transform:translate(-50%,-50%)}
  @media (prefers-reduced-motion:no-preference){
    .frame .bf-top img{animation:flutterA 2.6s ease-in-out infinite}
    .frame .bf-bot img{animation:flutterB 3.2s ease-in-out infinite}
  }
  @keyframes flutterA{0%,100%{transform:translateY(0) rotate(-5deg) scaleX(1)}50%{transform:translateY(-6px) rotate(5deg) scaleX(.9)}}
  @keyframes flutterB{0%,100%{transform:translateY(0) rotate(6deg) scaleX(1)}50%{transform:translateY(-5px) rotate(-6deg) scaleX(.92)}}

  /* ---- perfil ---- */
  .profile{text-align:center;margin-bottom:34px}
  .frame{
    position:relative;width:194px;aspect-ratio:254/338;margin:0 auto 14px;
    filter:drop-shadow(0 12px 20px rgba(74,59,56,.22));
  }
  .frame .photo{
    position:absolute;left:15.35%;top:22.19%;width:66.14%;height:65.68%;
    border-radius:50%;overflow:hidden;z-index:1;background:#e9d8d0;
  }
  .frame .photo img.puppet{
    width:100%;height:100%;object-fit:cover;object-position:center 12%;display:block;
    transform-origin:50% 55%;backface-visibility:hidden;
  }
  .frame .frameart{position:absolute;inset:0;width:100%;height:100%;z-index:2;pointer-events:none;display:block}
  @media (prefers-reduced-motion:no-preference){
    .frame .photo img.puppet{animation:puppet 2.8s ease-in-out infinite}
  }
  @keyframes puppet{0%,100%{transform:scale(1.12) rotate(0)}25%{transform:scale(1.12) rotate(-3deg)}50%{transform:scale(1.12) rotate(0)}75%{transform:scale(1.12) rotate(3deg)}}

  .initials{
    font-family:'Fraunces',serif;font-size:38px;font-weight:500;
    color:var(--blush);letter-spacing:1px;
  }
  .name{
    font-family:'Fraunces',serif;
    font-size:30px;font-weight:500;letter-spacing:.3px;line-height:1;
    margin-bottom:8px;
  }
  .handle{font-size:13.5px;color:var(--rose-deep);letter-spacing:1.5px;text-transform:uppercase;font-weight:500}
  .tagline{margin-top:12px;font-size:14.5px;color:var(--muted);line-height:1.5}
  .loc{
    margin-top:12px;display:inline-flex;align-items:center;gap:6px;
    font-size:12px;color:var(--muted);letter-spacing:1px;text-transform:uppercase;
  }
  .loc svg{width:12px;height:12px;stroke:var(--rose);fill:none;stroke-width:1.6}

  /* ---- divisória ---- */
  .rule{
    display:flex;align-items:center;gap:14px;
    margin:6px 4px 24px;color:var(--rose);
  }
  .rule::before,.rule::after{content:"";flex:1;height:1px;background:var(--line)}
  .rule span{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--muted)}

  /* ---- links ---- */
  .links{display:flex;flex-direction:column;gap:13px}
  .link{
    display:flex;align-items:center;gap:15px;
    background:var(--blush);
    border:1px solid var(--line);
    border-radius:16px;
    padding:16px 18px;
    text-decoration:none;color:var(--ink);
    transition:transform .22s ease,box-shadow .22s ease,border-color .22s ease;
    box-shadow:0 1px 0 rgba(74,59,56,.02);
  }
  .link:hover,.link:focus-visible{
    transform:translateY(-2px);
    border-color:var(--rose);
    box-shadow:0 10px 22px -12px rgba(135,90,82,.45);
    outline:none;
  }
  .ic{
    flex:none;width:38px;height:38px;border-radius:11px;
    background:#F3E5DF;
    display:flex;align-items:center;justify-content:center;
  }
  .ic svg{width:19px;height:19px;stroke:var(--rose-deep);fill:none;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round}
  .txt{flex:1;min-width:0}
  .txt b{display:block;font-family:'Jost';font-weight:500;font-size:15.5px;letter-spacing:.2px}
  .txt small{display:block;font-size:12.5px;color:var(--muted);margin-top:2px}
  .arrow{flex:none;stroke:var(--line);stroke-width:1.8;width:16px;height:16px;fill:none;transition:stroke .22s,transform .22s}
  .link:hover .arrow{stroke:var(--rose);transform:translateX(3px)}

  /* ---- CTA marcas ---- */
  .cta{
    margin-top:6px;
    background:linear-gradient(150deg,var(--rose) 0%,var(--rose-deep) 100%);
    border:none;
  }
  .cta .ic{background:rgba(255,255,255,.18)}
  .cta .ic svg{stroke:#fff}
  .cta .txt b{color:#fff}
  .cta .txt small{color:rgba(255,255,255,.82)}
  .cta .arrow{stroke:rgba(255,255,255,.7)}
  .cta:hover{box-shadow:0 14px 26px -12px rgba(135,90,82,.6)}
  .cta:hover .arrow{stroke:#fff}

  /* ---- rodapé ---- */
  .foot{text-align:center;margin-top:30px}
  .foot .by{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--muted)}
  .foot .by b{font-family:'Fraunces',serif;font-weight:500;letter-spacing:1px;color:var(--rose-deep)}

  /* ---- entrada ---- */
  @media (prefers-reduced-motion:no-preference){
    .reveal{opacity:0;transform:translateY(14px);animation:rise .6s ease forwards}
    .profile{animation-delay:.05s}
    .rule{animation-delay:.15s}
    .links .link:nth-child(1){animation-delay:.22s}
    .links .link:nth-child(2){animation-delay:.30s}
    .links .link:nth-child(3){animation-delay:.38s}
    .links .link:nth-child(4){animation-delay:.46s}
    .links .link:nth-child(5){animation-delay:.54s}
    .foot{animation-delay:.62s}
  }
  @keyframes rise{to{opacity:1;transform:translateY(0)}}
</style>
</head>
